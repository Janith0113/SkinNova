  "faq_training": [
    {
      "question": "What's the difference between tuberculoid and lepromatous leprosy?",
      "answer": "Tuberculoid (TT) has few lesions with strong immune response, while lepromatous (LL) has many lesions with weak immunity. TT patients have marked sensory loss early, while LL patients develop it late. TT is less contagious and has better prognosis, but both are curable with MDT.",
      "source": "WHO Classification System"
    },
    {
      "question": "Why is my leprosy classified as borderline?",
      "answer": "Borderline forms (BT, BB, BL) are intermediate between tuberculoid and lepromatous. They often show unstable immunity that can shift toward TT or LL. This means your doctor may need more careful monitoring, especially for reactions.",
      "source": "ILA Standards"
    },
    {
      "question": "What does 'paucibacillary' mean?",
      "answer": "Paucibacillary means 'few bacilli.' These forms (TT, BT) have low bacterial loads and are less contagious. Treatment is typically 6 months.",
      "source": "WHO Terminology"
    },
    {
      "question": "What does 'multibacillary' mean?",
      "answer": "Multibacillary means 'many bacilli.' These forms (BL, LL, and sometimes BB) have higher bacterial loads and require longer treatment (12 months) to completely clear the bacteria.",
      "source": "WHO Terminology"
    }
