# Environment Configuration
# Copy this file to .env.local and update values as needed

# Application
NEXT_PUBLIC_APP_NAME="Tinea Detector"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Model Configuration
NEXT_PUBLIC_MODEL_URL="/model/model.json"
NEXT_PUBLIC_METADATA_URL="/model/metadata.json"

# API Configuration (if using cloud storage for model)
# NEXT_PUBLIC_MODEL_BUCKET="your-bucket-name"
# NEXT_PUBLIC_API_KEY="your-api-key"

# Analytics (optional)
# NEXT_PUBLIC_GA_ID="your-ga-id"
